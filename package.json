{
  "name": "sailing-race-supporter",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:pages",
    "build:pages": "tsc -b && vite build --config vite.pages.config.ts && node scripts/prepare-pages.mjs",
    "build:cloudflare": "tsc -b && vite build && node scripts/remove-local-secret-artifacts.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:worker": "vitest run --config vitest.worker.config.ts --max-workers=1 --no-isolate",
    "test:all": "npm test && npm run test:worker",
    "test:watch": "vitest",
    "preview": "npm run build:cloudflare && vite preview",
    "deploy": "npm run deploy:worker",
    "deploy:worker": "node scripts/deploy-worker.mjs",
    "cf:preflight": "node scripts/deploy-worker.mjs --check",
    "cf-typegen": "wrangler types --config wrangler.worker.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply sailing-race-supporter --local --config wrangler.worker.jsonc",
    "db:migrate:remote": "node scripts/check-cloudflare-config.mjs && wrangler d1 migrations apply sailing-race-supporter --remote --config wrangler.worker.jsonc",
    "cf:check": "node scripts/check-cloudflare-config.mjs && wrangler whoami",
    "backup-key:generate": "node scripts/generate-backup-signing-key.mjs"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.5",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.544.0",
    "maplibre-gl": "^5.7.1",
    "pbf": "^4.0.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.13.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.4",
    "globals": "^17.7.0",
    "jsdom": "^27.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
